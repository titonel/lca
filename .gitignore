# =============================================================================
# SEGURANÇA — nunca subir para o repositório
# =============================================================================

# Variáveis de ambiente e segredos
.env
.env.*
*.env
secrets.py
local_settings.py
settings_local.py
settings_prod.py

# =============================================================================
# DJANGO
# =============================================================================

# Banco de dados local
*.sqlite3
*.db

# Arquivos de log
*.log
logs/

# Arquivos de mídia enviados por usuários
media/

# Arquivos estáticos coletados (gerados por collectstatic)
staticfiles/
static_root/

# Arquivos de migrações (gerados automaticamente — não versionar)
*/migrations/*.py
!*/migrations/__init__.py

# =============================================================================
# PYTHON
# =============================================================================

# Bytecode compilado
__pycache__/
*.py[cod]
*.pyo
*.pyd

# Distribuição / empacotamento
*.egg
*.egg-info/
dist/
build/
.eggs/
wheels/
*.whl
MANIFEST

# =============================================================================
